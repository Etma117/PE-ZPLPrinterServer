# URL base de tu backend POS
BACKEND_URL=http://127.0.0.1:8000

# Usuario del sistema (tabla Usuarios) con permisos de impresion
# Debe tener la ruta /sistema/impresoras-termicas en su Puesto o __ALL__
PRINT_USER=Admin
PRINT_PASSWORD=admin123
IMPRESORA_ID=1

# Polling
POLL_INTERVAL_SECONDS=10
FETCH_LIMIT=25
REQUEST_TIMEOUT_SECONDS=20

# Backend de impresion
# Valores: file | lp | command
PRINT_BACKEND=command

# Si PRINT_BACKEND=lp (CUPS/Linux/macOS)
PRINTER_NAME=

# Direccion de la impresora por red (IP:puerto). Usada por PRINT_BACKEND=network o por el comando Python
PRINTER_ADDRESS=192.168.1.70:9100

# Si PRINT_BACKEND=command. Ejecuta scripts/print.py (sin comillas; usa PRINTER_ADDRESS de arriba)
PRINT_COMMAND=python scripts/print.py

USE_PDF_PREVIEW=1

OUTPUT_DIR=./outbox
# Para impresora térmica de tickets (Epson, RIBETEC POS)
#RENDER_MODE=escpos

# Para impresora de etiquetas ZPL (Zebra, RIBETEC label)
RENDER_MODE=zpl
LOGO_IMAGE_PATH=./cmd/printspooler/logo.png


# Debug opcional
LOG_JSON_PAYLOAD=false
