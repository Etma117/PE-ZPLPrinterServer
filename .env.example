# URL base de tu backend POS
BACKEND_URL=http://localhost:5000

# Usuario del sistema (tabla Usuarios) con permisos de impresion
# Debe tener la ruta /sistema/impresoras-termicas en su Puesto o __ALL__
PRINT_USER=impresion@tuempresa.com
PRINT_PASSWORD=tu_password

# Polling
POLL_INTERVAL_SECONDS=10
FETCH_LIMIT=25
REQUEST_TIMEOUT_SECONDS=20

# Backend de impresion
# Valores: file | lp | command
PRINT_BACKEND=file

# Si PRINT_BACKEND=lp (CUPS/Linux/macOS)
PRINTER_NAME=

# Si PRINT_BACKEND=command
# Ejemplo Linux: lp -d Epson_TMT20
# Ejemplo Windows (PowerShell): powershell -File C:\\scripts\\print.ps1
# Prueba sin impresora (abre preview y usas Imprimir > Microsoft Print to PDF):
#   PRINT_COMMAND=python scripts/print.py
#   USE_PDF_PREVIEW=1
#   (deja PRINTER_ADDRESS vacio o usa USE_PDF_PREVIEW=1)
PRINT_COMMAND=

# Para scripts/print.py: IP:puerto de la impresora ZPL. Si esta vacio o USE_PDF_PREVIEW=1,
# el script renderiza la etiqueta a PNG y la abre (para imprimir a PDF).
PRINTER_ADDRESS=
USE_PDF_PREVIEW=1

# Si PRINT_BACKEND=file
OUTPUT_DIR=./outbox

# Ruta del logo PNG/JPG a imprimir en la etiqueta ZPL (frente)
# Copia el logo del frontend a este path en el servicio Go.
LOGO_IMAGE_PATH=./cmd/printspooler/logo.png

# Debug opcional
LOG_JSON_PAYLOAD=false

# Render:
# - zpl (etiqueta 4x6)
RENDER_MODE=zpl

# Tamaño del QR en la etiqueta ZPL, en puntos (dots) a 203 dpi. Ancho de etiqueta = 812.
# Valores típicos: 380 (pequeño), 700 (grande, similar al PDF), 812 (casi todo el ancho).
QR_SIZE_DOTS=700
